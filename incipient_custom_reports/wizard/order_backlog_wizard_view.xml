<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View for the Wizard -->
    <record id="view_order_backlog_wizard_form" model="ir.ui.view">
        <field name="name">order.backlog.wizard.form</field>
        <field name="model">order.backlog.wizard</field>
        <field name="arch" type="xml">
            <form string="Order Backlog Report">
                <sheet>
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="backlog_thru"/>
                        </group>
                        <group>
                            <field name="partner_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report" string="Print PDF" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for the Wizard -->
    <record id="action_order_backlog_wizard" model="ir.actions.act_window">
        <field name="name">Order Backlog Report</field>
        <field name="res_model">order.backlog.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_order_backlog_wizard_form"/>
        <field name="target">new</field>
    </record>

    <!-- Menu Item (Inventory -> Reporting -> Order Backlog Report) -->
    <menuitem id="menu_order_backlog_report"
              name="Order Backlog Report"
              parent="stock.menu_warehouse_report"
              action="action_order_backlog_wizard"
              sequence="160" />

</odoo>
